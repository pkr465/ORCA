# ============================================================================
# ORCA Environment — API Keys Only
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp env.example .env
#
# All other configuration (paths, database, LLM model/provider, adapters,
# reporting, etc.) lives in global_config.yaml — edit that file to customise.
#
# Load before running ORCA:
#   export $(grep -v '^#' .env | xargs)
# ============================================================================

# ── Generic LLM API Key ─────────────────────────────────────────────────
# Used when llm.provider is "anthropic" or "openai" (or any future provider).
# Set this to your Anthropic or OpenAI key depending on the provider you chose
# in global_config.yaml.
LLM_API_KEY=""

# ── QGenie API Key ───────────────────────────────────────────────────────
# Required only when llm.provider is "qgenie".
QGENIE_API_KEY=""
